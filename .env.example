# =====================================================
# ENVIRONMENT VARIABLES FOR HABIBSTAY
# =====================================================
# Copy this file to .env.local for local development
# Add these variables to Vercel Environment Variables for production

# =====================================================
# SUPABASE CONFIGURATION
# =====================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# =====================================================
# API CONFIGURATION
# =====================================================
VITE_API_BASE_URL=https://api.habibstay.com
VITE_API_KEY=your-api-key

# =====================================================
# PAYMENT GATEWAYS
# =====================================================
# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# PayPal
VITE_PAYPAL_CLIENT_ID=xxxxx
PAYPAL_CLIENT_SECRET=xxxxx

# =====================================================
# AI CONFIGURATION (SARA)
# =====================================================
OPENAI_API_KEY=sk-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx
AI_MODEL=gpt-4
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7

# =====================================================
# EMAIL SERVICE
# =====================================================
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.xxxxx
EMAIL_FROM=noreply@habibstay.com
EMAIL_FROM_NAME=HabibStay

# For SMTP (alternative)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# =====================================================
# CLOUD STORAGE
# =====================================================
# For image uploads (if not using Supabase Storage)
CLOUDINARY_CLOUD_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx

# =====================================================
# ANALYTICS & MONITORING
# =====================================================
VITE_GA_MEASUREMENT_ID=G-xxxxx
VITE_HOTJAR_ID=xxxxx
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# =====================================================
# SOCIAL MEDIA
# =====================================================
VITE_FACEBOOK_APP_ID=xxxxx
VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# =====================================================
# MAPS & LOCATION
# =====================================================
VITE_GOOGLE_MAPS_API_KEY=xxxxx
VITE_MAPBOX_ACCESS_TOKEN=pk.xxxxx

# =====================================================
# SECURITY
# =====================================================
JWT_SECRET=your-super-secret-jwt-key
ENCRYPTION_KEY=your-32-character-encryption-key
SESSION_SECRET=your-session-secret

# =====================================================
# RATE LIMITING
# =====================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =====================================================
# ENVIRONMENT
# =====================================================
NODE_ENV=production
VITE_APP_ENV=production
VITE_DEBUG=false

# =====================================================
# VERCEL SPECIFIC
# =====================================================
VERCEL_URL=$VERCEL_URL
VERCEL_ENV=$VERCEL_ENV

# =====================================================
# DATABASE (if using external DB)
# =====================================================
DATABASE_URL=postgresql://user:password@host:5432/database
REDIS_URL=redis://user:password@host:6379

# =====================================================
# FEATURE FLAGS
# =====================================================
VITE_ENABLE_AI_CHAT=true
VITE_ENABLE_INVESTMENTS=true
VITE_ENABLE_INSTANT_BOOKING=true
VITE_ENABLE_CRYPTO_PAYMENTS=false
VITE_MAINTENANCE_MODE=false

# =====================================================
# COMMISSION & FEES
# =====================================================
BOOKING_COMMISSION_RATE=0.15
INVESTMENT_COMMISSION_RATE=0.02
SERVICE_FEE_RATE=0.05
TAX_RATE=0.10

# =====================================================
# BOOKING POLICIES
# =====================================================
MIN_ADVANCE_BOOKING_DAYS=1
MAX_ADVANCE_BOOKING_DAYS=365
CANCELLATION_WINDOW_HOURS=24
MAX_GUESTS_PER_BOOKING=20

# =====================================================
# CRON JOBS
# =====================================================
CRON_SECRET=your-cron-secret
ENABLE_SCHEDULED_TASKS=true